      capacitance : 0.0010;
    }
    pin("gpio_out[1]") {
      direction : output;
      capacitance : 0.0004;
    }
    pin("gpio_out[0]") {
      direction : output;
      capacitance : 0.0007;
    }
    }
  }

}
